<entity-facade-xml xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/entity-facade-3.xsd" type="seed-initial">

    <!-- Root graph record for the offline-generated Moqui artifact graph.
         GraphVertex and GraphEdge rows are intentionally not seeded statically:
         they must derive from real artifact graph output and then be loaded if
         and when the graph is materialized in moqui.math entities. -->
    <moqui.math.Graph
            graphId="AgentArtifactGraph"
            loopsAllowed="N"
            isConnected="N"
            isWeighted="N"
            name="Agent Artifact Graph"
            description="Root directed multigraph for offline-generated Moqui agent artifacts, service actions, entity fields, and runtime derivation links."/>

</entity-facade-xml>
