<entity-facade-xml type="seed-initial">
    <!--
        Compatibility seed for Graph/GraphEdge enumerations expected by moqui.math.
        In some local runtimes these seed-data blocks may not have been loaded yet,
        which makes GraphEdge inserts fail on GetDirected/GetUndirected foreign keys.
    -->
    <moqui.basic.EnumerationType enumTypeId="GraphType" description="Graph Type"/>
    <moqui.basic.Enumeration enumId="GtDirected" enumTypeId="GraphType" description="Directed"/>
    <moqui.basic.Enumeration enumId="GtDirectedMulti" enumTypeId="GraphType" parentEnumId="GtDirected" description="Directed Multigraph"/>

    <moqui.basic.EnumerationType enumTypeId="GraphEdgeType" description="Graph Edge Type"/>
    <moqui.basic.Enumeration enumId="GetUndirected" enumTypeId="GraphEdgeType" description="Undirected Edge"/>
    <moqui.basic.Enumeration enumId="GetDirected" enumTypeId="GraphEdgeType" description="Directed Edge"/>
</entity-facade-xml>
