<entities xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/entity-definition-3.xsd">

    <!--
        Cache for query-time embeddings: text → vector.

        Persistent query embedding cache used by AgentDocumentServices.get#QueryEmbedding.
        Legacy RagServices no longer implements production vector/hybrid retrieval.
        L1 cache: JVM ConcurrentHashMap (in-process, lost on restart)
        L2 cache: this entity (persistent, survives restart)

        Cache key: sha1(provider | model | dimensions | normalizedQueryText)
        Invalidation: manual or by TTL (query lastUsedDate < now - N days).
    -->
    <entity entity-name="ArtifactQueryEmbeddingCache" package="moqui.rag" use="nontransactional">
        <field name="cacheKey" type="id" is-pk="true" enable-audit-log="false"/>
        <field name="queryTextNorm" type="text-medium" enable-audit-log="false"/>
        <field name="embeddingProvider" type="text-short" enable-audit-log="false"/>
        <field name="embeddingModel" type="text-short" enable-audit-log="false"/>
        <field name="embeddingDimensions" type="number-integer" enable-audit-log="false"/>
        <!-- JSON array of floats, e.g. [0.123, -0.456, ...] -->
        <field name="embeddingJson" type="text-very-long" enable-audit-log="false"/>
        <field name="createdDate" type="date-time" enable-audit-log="false"/>
        <field name="lastUsedDate" type="date-time" enable-audit-log="false"/>
        <field name="hitCount" type="number-integer" enable-audit-log="false"/>
    </entity>
</entities>
